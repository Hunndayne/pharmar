# ============================================================
# PHARMAR MANAGEMENT SYSTEM - Environment Variables Template
# Tên miền production: pharmar.hunn.io.vn
# ============================================================
# Copy file này thành .env và điền các giá trị thực tế
# cp .env.example .env
# ============================================================

# ---- APP ENVIRONMENT ----------------------------------------
# Đặt "production" để bật các kiểm tra bảo mật bắt buộc
APP_ENV=production

# ---- JWT SECRET (BẮT BUỘC THAY ĐỔI) ------------------------
# Tạo bằng: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_USE_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# ---- INTERNAL SERVICE API KEY (BẮT BUỘC THAY ĐỔI) ----------
# Tạo bằng: python -c "import secrets; print(secrets.token_urlsafe(32))"
CUSTOMER_INTERNAL_API_KEY=CHANGE_ME_USE_STRONG_RANDOM_KEY

# ---- DATABASE PASSWORD (BẮT BUỘC THAY ĐỔI) -----------------
# Tạo bằng: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ---- CORS ORIGINS (cấu hình theo domain thực) ---------------
# Cho production với domain pharmar.hunn.io.vn:
CORS_ALLOWED_ORIGINS=["https://pharmar.hunn.io.vn","http://localhost:3000"]

# ---- FRONTEND API URL (production: dùng domain, dev: dùng /) -
# Production behind Nginx (API proxy qua /api/):
VITE_API_BASE_URL=https://apipharmar.hunn.io.vn
# Hoặc nếu API Gateway expose trực tiếp:
# VITE_API_BASE_URL=/

# ---- JWT ALGORITHM (không cần thay đổi) --------------------
JWT_ALGORITHM=HS256

# ---- TOKEN EXPIRY (tuỳ chỉnh) ------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- PAYMENT QR (cấu hình cho tính năng QR code) -----------
VIETQR_URL=https://api.vietqr.io/v2/generate
# VIETQR_CLIENT_ID=your_vietqr_client_id
# VIETQR_API_KEY=your_vietqr_api_key

# ---- SALE SERVICE OPTIONS ----------------------------------
HELD_ORDER_EXPIRE_MINUTES=30
ENABLE_HELD_ORDER_CLEANUP_JOB=true
REQUIRE_SHIFT_FOR_SALE=false
DEFAULT_COMMISSION_RATE=1.5

# ---- CUSTOMER SERVICE OPTIONS ------------------------------
ENABLE_POINTS_EXPIRY_JOB=true
POINTS_EXPIRY_JOB_INTERVAL_HOURS=24

# ---- FILE SERVICE (Cloudflare R2) -------------------------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=pharmar-files
# R2_PUBLIC_DOMAIN=files.pharmar.hunn.io.vn
MAX_UPLOAD_SIZE_MB=50

# ---- STORE -> FILE SERVICE (auto backup sync to R2) -------
FILE_SERVICE_URL=http://file-service:8009
