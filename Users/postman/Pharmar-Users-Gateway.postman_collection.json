  "item": [
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Login Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.environment.set(\"owner_id\", String(data.user.id));",
                  "pm.environment.set(\"access_token\", data.token.access_token);",
                  "pm.environment.set(\"refresh_token\", data.token.refresh_token);",
                  "pm.environment.set(\"auth_token\", data.token.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{owner_username}}\",\n  \"password\": \"{{owner_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/auth/login"
          },
          "response": []
        },
