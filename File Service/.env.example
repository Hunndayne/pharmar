# ---- APP ----
APP_NAME=File Service
APP_PORT=8009
APP_ENV=development
# PUBLIC_URL=https://apipharmar.hunn.io.vn

# ---- DATABASE (uses pharmar_store schema file_storage) ----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pharmar_store?sslmode=disable

# ---- JWT (same as other services) ----
JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256

# ---- CLOUDFLARE R2 ----
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=pharmar-files
# Public domain if R2 bucket has public access or custom domain via Cloudflare
# R2_PUBLIC_DOMAIN=files.pharmar.hunn.io.vn

# ---- UPLOAD LIMITS ----
MAX_UPLOAD_SIZE_MB=50

# ---- CORS ----
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
